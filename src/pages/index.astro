---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Simulateur d'impôt sur le revenu">
  <main class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="text-2xl font-bold text-center mb-8">
      Simulateur d'impôt sur le revenu
    </h1>
    <p class="text-center text-gray-600 mb-4">
      Barème 2026 — revenus 2025
    </p>
    <!-- SimulatorApp React component will be added here -->
  </main>

  <footer class="text-center text-sm text-gray-500 py-8">
    <p>Ce simulateur est fourni à titre indicatif et ne se substitue pas aux calculs officiels de l'administration fiscale.</p>
  </footer>
</Layout>
